---
import { site } from '~/site'
import type { Locales } from '~/i18n/type.d.ts'
import Layout from '~/layouts/Layout.astro'
import AppModal from '~/components/AppModal.svelte'
import LocaleSwitch from '~/components/LocaleSwitch.astro'
import AppForm from '~/components/AppForm.svelte'
import AppContent from '~/components/AppContent.svelte'
import Footer from '~/components/Footer.astro'

import { i18nFactory } from '~/i18n'
const _ = i18nFactory(Astro.currentLocale as Locales | undefined)
---

<Layout
	bodyClass="bg-o2o-tint-blue h-screen"
>

	<AppModal locale={Astro.currentLocale as Locales | undefined} client:load />

	<div class="flex flex-col justify-center items-center min-h-full overflow-y gap-8 p-8 w-full max-w-[calc(1600px+2*2rem)] mx-auto">
		<div class="bg-white shadow-lg rounded-lg p-6 w-full space-y-4">
			<div class="flex items-start justify-between gap-4">
				<div class="flex items-center gap-3">
					<img src="/o2o-logo.svg" alt="o2o" class="h-10 w-auto shrink-0" />
					<h1 class="text-3xl font-bold text-o2o-text leading-none">
						eml reader
					</h1>
				</div>
				<LocaleSwitch />
			</div>
			{site.description &&
				<p class="text-gray-600">
					{_(site.description)}
				</p>
			}

			<AppForm class="home text-black group-hover:text-gray mt-4" locale={Astro.currentLocale as Locales | undefined} client:load />
		</div>

		<AppContent locale={Astro.currentLocale as Locales | undefined} client:load />

		<section class="bg-white shadow-lg rounded-lg p-6 w-full space-y-3">
			<h2 class="text-xl font-bold text-o2o-text flex items-center gap-2">
				<span class="icon-[mdi--bike] icon-align"></span>
				{_({ en: 'Why "Emiel"?', fr: 'Pourquoi « Emiel » ?' })}
			</h2>
			<p class="text-gray-600">
				{_({
					en: 'Honestly? No particular rider. The pun came first — in Flemish, "Emiel" sounds almost exactly like "e-mail" — and it\'s simply the old Flandrien first name, alongside Odiel, Briek and Stan.',
					fr: 'Honnêtement ? Aucun coureur en particulier. Le jeu de mots est venu d\'abord — en flamand, « Emiel » se prononce presque comme « e-mail » — et c\'est simplement l\'ancien prénom de Flandrien, aux côtés d\'Odiel, Briek et Stan.',
				})}
			</p>
			<p class="text-gray-600">
				{_({
					en: 'Want a real rider to pin it on? Emiel Faignaert won the 1947 Tour of Flanders. But it works without a palmarès too — just hand that .eml to Emiel.',
					fr: 'Envie d\'un vrai coureur à y accrocher ? Emiel Faignaert a remporté le Tour des Flandres en 1947. Mais ça marche aussi sans palmarès : confiez donc ce .eml à Emiel.',
				})}
			</p>
		</section>

		<Footer class="w-full" />
	</div>

</Layout>
